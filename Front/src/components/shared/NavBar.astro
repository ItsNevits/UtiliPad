---
import BarsIcon from "@assets/icons/bars.svg";
import ArrowDownIcon from "@assets/icons/arrow-down.svg";
import BookLoadingGif from "@assets/gifs/book-loading.gif";
import Picture from "astro/components/Picture.astro";
---

<nav
  id="navbar"
  class="flex gap-4 text-lg sticky top-0 border-b border-white/10 py-2 justify-between md:justify-start z-100"
>
  <a id="logo" class="px-2 flex items-center" href="#">
    <Picture src={BookLoadingGif} alt="Book Loading" class="w-8 h-8" />
    <span class="ml-2 font-bold text-xl">UtiliPad</span>
  </a>
  <div class="flex items-center">
    <div class="hidden md:flex gap-4 px-2">
      <ul id="menu-items" class="flex gap-4">
        <li class="list-none relative group">
          <button
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            class="cursor-pointer border-b border-b-transparent hover:border-b border-b-accent-400 transition-all flex items-center"
            onclick="toggleDropdown(this)"
          >
            Textos
            <Picture
              src={ArrowDownIcon}
              alt="Arrow Down Icon"
              class="w-5 h-5 ml-1 icon-white transition-transform group-hover:rotate-180"
            />
          </button>

          <ul
            class="absolute left-0 top-full mt-3 min-w-60 max-w-80 bg-ink-900 border border-white/10 rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-20 backdrop-blur-md bg-ink-950/80"
          >
            <li>
              <a
                href="/text-tools?content=json-formatter"
                class="block px-4 py-2 border-b border-b-transparent rounded-md hover:bg-white/10 transition-all"
                >Formateador de JSON</a
              >
            </li>
            <li>
              <a
                href="/text-tools?content=character-counter"
                class="block px-4 py-2 border-b border-b-transparent rounded-md hover:bg-white/10 transition-all"
                >Contador de caracteres</a
              >
            </li>
          </ul>
        </li>
      </ul>
    </div>
    <div class="md:hidden relative flex justify-center items-center">
      <button onclick="menu.hidden^=1" class="px-2">
        <Picture src={BarsIcon} alt="Menu Icon" class="w-6 h-6 icon-white" />
      </button>
      <ul
        id="menu"
        hidden
        class="absolute top-full right-0 z-10 w-dvw border-b border-white/10 backdrop-blur-md bg-ink-950/80 py-2"
      >
        <li class="list-none text-end">
          <button
            class="w-full text-right py-2 px-2 rounded hover:bg-accent-500/10 hover:text-accent-400 transition-all flex items-center justify-end"
            onclick="toggleMobileSubmenu(this)"
          >
            Textos
            <Picture
              src={ArrowDownIcon}
              alt="Arrow Down Icon"
              class="w-4 h-4 ml-1 icon-white transition-transform duration-200"
            />
          </button>
          <ul class="hidden bg-ink-900/50 mt-1 border-t border-white/5">
            <li>
              <a
                href="/text-tools?content=json-formatter"
                class="block py-2 px-4 text-sm hover:bg-accent-500/10 hover:text-accent-400 transition-all"
                >Formateador de JSON</a
              >
            </li>
            <li>
              <a
                href="/text-tools?content=character-counter"
                class="block py-2 px-4 text-sm hover:bg-accent-500/10 hover:text-accent-400 transition-all"
                >Contador de caracteres</a
              >
            </li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  // Hacer las funciones globales para que funcionen con onclick en Astro
  declare global {
    interface Window {
      toggleDropdown: (button: HTMLButtonElement) => void;
      toggleMobileSubmenu: (button: HTMLButtonElement) => void;
    }
  }

  function toggleDropdown(button: HTMLButtonElement) {
    const dropdown = button.nextElementSibling as HTMLElement;
    const isOpen = dropdown.classList.contains("opacity-100");

    // Cerrar todos los otros dropdowns de desktop
    document.querySelectorAll(".group ul").forEach((d: Element) => {
      if (d !== dropdown) {
        d.classList.add("opacity-0", "invisible");
        d.classList.remove("opacity-100", "visible");
      }
    });

    // Cerrar botones de desktop
    document
      .querySelectorAll('button[aria-haspopup="true"]')
      .forEach((btn: Element) => {
        if (btn !== button) {
          btn.setAttribute("aria-expanded", "false");
        }
      });

    // Toggle este dropdown
    if (!isOpen) {
      dropdown.classList.remove("opacity-0", "invisible");
      dropdown.classList.add("opacity-100", "visible");
      button.setAttribute("aria-expanded", "true");
    } else {
      dropdown.classList.add("opacity-0", "invisible");
      dropdown.classList.remove("opacity-100", "visible");
      button.setAttribute("aria-expanded", "false");
    }
  }

  function toggleMobileSubmenu(button: HTMLButtonElement) {
    const submenu = button.nextElementSibling as HTMLElement;
    const arrow = button.querySelector("picture") as HTMLElement;
    const isHidden = submenu.classList.contains("hidden");

    // Cerrar otros submenús móviles
    document.querySelectorAll("#menu ul").forEach((menu: Element) => {
      if (menu !== submenu && menu.classList.contains("hidden") === false) {
        menu.classList.add("hidden");
      }
    });

    // Resetear otras flechas móviles
    document
      .querySelectorAll("#menu button picture")
      .forEach((pic: Element) => {
        if (pic !== arrow) {
          (pic as HTMLElement).style.transform = "rotate(0deg)";
        }
      });

    // Toggle este submenú
    if (isHidden) {
      submenu.classList.remove("hidden");
      if (arrow) arrow.style.transform = "rotate(180deg)";
    } else {
      submenu.classList.add("hidden");
      if (arrow) arrow.style.transform = "rotate(0deg)";
    }
  }

  // Exponer las funciones globalmente para onclick
  window.toggleDropdown = toggleDropdown;
  window.toggleMobileSubmenu = toggleMobileSubmenu;

  // Cerrar dropdowns al hacer click fuera
  document.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;
    if (target && !target.closest(".group") && !target.closest("#menu")) {
      // Cerrar dropdowns de desktop
      document.querySelectorAll(".group ul").forEach((d: Element) => {
        d.classList.add("opacity-0", "invisible");
        d.classList.remove("opacity-100", "visible");
      });

      // Resetear aria-expanded de desktop
      document
        .querySelectorAll('button[aria-haspopup="true"]')
        .forEach((btn: Element) => {
          btn.setAttribute("aria-expanded", "false");
        });
    }
  });

  // Cerrar menú móvil al hacer click en un enlace
  document.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;
    if (target && target.matches("#menu a")) {
      const menu = document.getElementById("menu");
      if (menu) {
        menu.hidden = true;
        // Cerrar todos los submenús móviles
        menu.querySelectorAll("ul").forEach((submenu: Element) => {
          submenu.classList.add("hidden");
        });
        // Resetear flechas
        menu.querySelectorAll("picture").forEach((pic: Element) => {
          (pic as HTMLElement).style.transform = "rotate(0deg)";
        });
      }
    }
  });

  // Inicialización para Astro
  function initializeDropdowns() {
    // Asegurar que todos los dropdowns estén cerrados al cargar
    document.querySelectorAll(".group ul").forEach((d: Element) => {
      d.classList.add("opacity-0", "invisible");
      d.classList.remove("opacity-100", "visible");
    });

    document
      .querySelectorAll('button[aria-haspopup="true"]')
      .forEach((btn: Element) => {
        btn.setAttribute("aria-expanded", "false");
      });
  }

  // Ejecutar al cargar la página
  document.addEventListener("DOMContentLoaded", initializeDropdowns);
  document.addEventListener("astro:page-load", initializeDropdowns);
</script>
