import NavBar from "../components/shared/NavBar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UtiliPad</title>
  </head>
  <body
    class="bg-gray-950 text-white overflow-x-hidden flex flex-col h-full w-full"
  >
    <NavBar />
    <main class="max-w-[1200px] mx-auto px-4 flex flex-col flex-1 w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
